{
  "name": "corvus-agentic-workflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex-native agentic engineering workflow control plane for Corvus.",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "workflow:check": "node scripts/workflow-check.mjs",
    "check": "npm run workflow:check && npm run format:check && npm run typecheck && npm test",
    "afk": "node scripts/run-afk.mjs",
    "review": "bash scripts/codex-review.sh",
    "sandbox:auth": "node scripts/bootstrap-sandbox-auth.mjs",
    "sandcastle": "tsx .sandcastle/main.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "0.12.0",
    "@openai/codex-sdk": "0.144.6",
    "@types/node": "26.1.1",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "zod": "4.4.3"
  }
}
